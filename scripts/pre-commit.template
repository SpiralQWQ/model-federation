#!/bin/bash
# ============================================================
# V6.0 协同通行证 — Git Pre-commit Hook
# 任何核心代码修改必须持有 .ticket 通行证（由路由脚本签发）
# 无证提交 → BLOCKED exit 1
# ============================================================

LOCK_DIR=".claude/synergy_locks"
SOURCE_EXTS="py|vue|cpp|js|ts|h|c|cs|java|go|rs|swift|kt"

# 获取暂存区文件
STAGED=$(git diff --cached --name-only 2>/dev/null)
if [ -z "$STAGED" ]; then
    exit 0  # 无暂存文件，放行
fi

BLOCKED=0
TICKETS_FOUND=0

for file in $STAGED; do
    ext="${file##*.}"
    # 仅检查源代码文件
    if echo "$ext" | grep -qE "^($SOURCE_EXTS)$"; then
        basename=$(basename "$file")
        ticket="${LOCK_DIR}/${basename}.ticket"
        if [ -f "$ticket" ]; then
            TICKETS_FOUND=1
            echo "  [PASS] $file → ticket found"
        else
            BLOCKED=1
            echo "  [BLOCKED] $file → NO TICKET"
        fi
    fi
done

echo ""

if [ $BLOCKED -eq 1 ]; then
    echo "============================================"
    echo "[BLOCKED] 物理拦截：发现未经过 Qwen/GLM"
    echo "         三方协同审查的代码变动！"
    echo ""
    echo " 请先执行协同脚本获取通行证："
    echo "   python ~/.claude/scripts/dashscope_router.py code ..."
    echo ""
    echo " 禁止使用 --no-verify 绕过！"
    echo "============================================"
    exit 1
fi

# 全部通过 → 核销通行证
if [ $TICKETS_FOUND -eq 1 ]; then
    rm -f "${LOCK_DIR}"/*.ticket 2>/dev/null
    echo "[SYNERGY] 通行证核销完毕，提交放行。"
fi

exit 0
